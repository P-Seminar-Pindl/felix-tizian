[ext_resource type="Script" uid="uid://bhk7swk7xodpk" path="res://scripts/path_3d.gd" id="2_iip1w"]
[ext_resource type="Script" uid="uid://cwr01nyqika8a" path="res://scripts/path_follow_3d.gd" id="3_mufa6"]
[ext_resource type="ArrayMesh" uid="uid://cx320juvmmel6" path="res://assets/models/218.obj" id="5_2ivqk"]

[sub_resource type="GDScript" id="GDScript_mufa6"]
script/source = "extends Node3D

@export var path: Path3D
@export var thickness: float = 1
@export var samples: int = 100

func _ready() -> void:
	if path == null:
		return

func _make_line(side_offset: float) -> void:
	var points: Array[Vector3] = []

	# build quad strip: two triangles per segment
	var verts: PackedVector3Array = []
	var up := Vector3.UP * thickness

	for i in range(points.size() - 1):
		var a := points[i]
		var b := points[i + 1]
		# quad: two triangles
		verts.append(a - up)
		verts.append(a + up)
		verts.append(b + up)
		verts.append(a - up)
		verts.append(b + up)
		verts.append(b - up)

	var arr := []
	arr.resize(Mesh.ARRAY_MAX)
	arr[Mesh.ARRAY_VERTEX] = verts

	var am := ArrayMesh.new()
	am.add_surface_from_arrays(Mesh.PRIMITIVE_TRIANGLES, arr)

	var mi := MeshInstance3D.new()
	mi.mesh = am

	var mat := StandardMaterial3D.new()
	mat.shading_mode = BaseMaterial3D.SHADING_MODE_UNSHADED
	mat.albedo_color = Color.GREEN
	mat.cull_mode = BaseMaterial3D.CULL_DISABLED
	mi.material_override = mat

	add_child(mi)
"

